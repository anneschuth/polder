{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://polder.dev/schemas/persoon.schema.json",
  "title": "Persoon",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "sources"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Slug eindigt op een 4-cijferig geboortejaar, een numeriek extern ID (>=7 cijfers) of een 8-hex UUID-fallback-suffix.",
      "pattern": "^person:([a-z][a-z0-9-]*-)?([0-9]{4}|[0-9]{7,}|[0-9a-f]{8})$"
    },
    "identifiers": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "wikidata": { "type": ["string", "null"], "pattern": "^Q\\d+$" },
        "tk_persoon_id": { "type": ["string", "null"] },
        "abd_id": { "type": ["string", "null"] },
        "allmanak_id": { "type": ["string", "null"] }
      }
    },
    "name": {
      "type": "object",
      "additionalProperties": false,
      "required": ["full", "family"],
      "properties": {
        "full": { "type": "string" },
        "family": {
          "type": "string",
          "description": "Achternaam zonder tussenvoegsel. Voor sortering en slug-vorming. Voor 'Alies van Weperen' is dit 'Weperen'."
        },
        "tussenvoegsel": {
          "type": "string",
          "description": "Tussenvoegsel zoals 'van', 'de', 'van der', 'op de', 'in 't'. Geen vaste lijst; afgeleid uit bron-data."
        },
        "given": { "type": "string" },
        "initials": {
          "type": "string",
          "pattern": "^([A-Z]\\.)+$"
        },
        "honorifics_pre": {
          "type": "array",
          "items": { "type": "string" }
        },
        "honorifics_post": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "birth": {
      "type": "object",
      "additionalProperties": false,
      "required": ["year"],
      "properties": {
        "year": {
          "type": "integer",
          "minimum": 1850,
          "maximum": 2030
        }
      }
    },
    "gender": {
      "type": ["string", "null"],
      "enum": ["m", "f", "x", null]
    },
    "mandaten": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "organization_id",
          "post_id",
          "role",
          "start_date",
          "sources"
        ],
        "properties": {
          "id": { "type": "string" },
          "organization_id": {
            "type": "string",
            "pattern": "^org:[a-z0-9-]+$"
          },
          "post_id": {
            "type": "string",
            "pattern": "^post:[a-z0-9-]+$"
          },
          "role": { "type": "string" },
          "start_date": { "type": "string", "format": "date" },
          "end_date": {
            "oneOf": [
              { "type": "string", "format": "date" },
              { "type": "null" }
            ]
          },
          "appointment": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "decision": { "type": "string" },
              "staatscourant_url": { "type": "string", "format": "uri" },
              "kb_nummer": { "type": "string" }
            }
          },
          "sources": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "url", "retrieved"],
              "properties": {
                "id": { "type": "string" },
                "url": { "type": "string", "format": "uri" },
                "retrieved": { "type": "string", "format": "date" },
                "fields": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            }
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "url", "retrieved"],
        "properties": {
          "id": { "type": "string" },
          "url": { "type": "string", "format": "uri" },
          "retrieved": { "type": "string", "format": "date" },
          "fields": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
