{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://polder.dev/schemas/event.schema.json",
  "title": "Event",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "type", "date", "affected_org_ids", "description", "sources"],
  "properties": {
    "id": { "type": "string" },
    "type": {
      "type": "string",
      "enum": [
        "organization-renamed",
        "organization-merged",
        "organization-split",
        "organization-dissolved",
        "post-created",
        "post-abolished"
      ]
    },
    "date": { "type": "string", "format": "date" },
    "affected_org_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^org:[a-z0-9-]+$"
      }
    },
    "description": { "type": "string" },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "url", "retrieved"],
        "properties": {
          "id": { "type": "string" },
          "url": { "type": "string", "format": "uri" },
          "retrieved": { "type": "string", "format": "date" },
          "fields": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
