{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://polder.dev/schemas/mandaat.schema.json",
  "title": "Mandaat",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "person_id",
    "organization_id",
    "post_id",
    "role",
    "start_date",
    "sources"
  ],
  "properties": {
    "id": { "type": "string" },
    "person_id": {
      "type": "string",
      "pattern": "^person:[a-z0-9-]+$"
    },
    "organization_id": {
      "type": "string",
      "pattern": "^org:[a-z0-9-]+$"
    },
    "post_id": {
      "type": "string",
      "pattern": "^post:[a-z0-9-]+$"
    },
    "role": { "type": "string" },
    "start_date": { "type": "string", "format": "date" },
    "end_date": {
      "oneOf": [
        { "type": "string", "format": "date" },
        { "type": "null" }
      ]
    },
    "appointment": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "decision": { "type": "string" },
        "staatscourant_url": { "type": "string", "format": "uri" },
        "kb_nummer": { "type": "string" }
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "url", "retrieved"],
        "properties": {
          "id": { "type": "string" },
          "url": { "type": "string", "format": "uri" },
          "retrieved": { "type": "string", "format": "date" },
          "fields": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  }
}
