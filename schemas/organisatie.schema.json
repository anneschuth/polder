{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://polder.dev/schemas/organisatie.schema.json",
  "title": "Organisatie",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "type", "names", "valid_from", "sources"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^org:[a-z0-9-]+$"
    },
    "type": {
      "type": "string",
      "enum": [
        "ministerie",
        "agentschap",
        "zbo",
        "rwt",
        "hoge-college",
        "gemeente",
        "provincie",
        "waterschap",
        "gemeenschappelijke-regeling",
        "adviescollege",
        "inspectie",
        "rechterlijke-instantie",
        "politie",
        "openbaar-ministerie",
        "caribisch-openbaar-lichaam",
        "organisatieonderdeel"
      ]
    },
    "identifiers": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "oin": { "type": "string" },
        "tooi": { "type": "string", "format": "uri" },
        "wikidata": { "type": "string", "pattern": "^Q\\d+$" },
        "roo_id": { "type": "string" },
        "kvk": { "type": ["string", "null"] },
        "rsin": { "type": ["string", "null"] }
      }
    },
    "classification": { "type": "string" },
    "parent_id": {
      "type": ["string", "null"],
      "pattern": "^org:[a-z0-9-]+$"
    },
    "names": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["value", "valid_from"],
        "properties": {
          "value": { "type": "string" },
          "abbr": { "type": "string" },
          "valid_from": { "type": "string", "format": "date" },
          "valid_until": {
            "oneOf": [
              { "type": "string", "format": "date" },
              { "type": "null" }
            ]
          }
        }
      }
    },
    "contact": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "website": { "type": "string", "format": "uri" },
        "bezoekadres": { "type": "string" },
        "postadres": { "type": "string" },
        "email": { "type": "string", "format": "email" }
      }
    },
    "valid_from": { "type": "string", "format": "date" },
    "valid_until": {
      "oneOf": [
        { "type": "string", "format": "date" },
        { "type": "null" }
      ]
    },
    "successor_id": {
      "oneOf": [
        { "type": "string", "pattern": "^org:[a-z0-9-]+$" },
        { "type": "null" }
      ],
      "description": "Opvolger-organisatie bij hernoeming, fusie of splitsing."
    },
    "predecessor_id": {
      "oneOf": [
        {
          "type": "array",
          "items": { "type": "string", "pattern": "^org:[a-z0-9-]+$" }
        },
        { "type": "null" }
      ],
      "description": "Voorganger(s). Array bij fusies van meerdere voorgangers."
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "url", "retrieved"],
        "properties": {
          "id": { "type": "string" },
          "url": { "type": "string", "format": "uri" },
          "retrieved": { "type": "string", "format": "date" },
          "fields": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
