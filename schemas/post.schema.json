{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://polder.dev/schemas/post.schema.json",
  "title": "Post",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "organization_id", "label", "classification", "valid_from"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^post:[a-z0-9-]+$"
    },
    "organization_id": {
      "type": "string",
      "pattern": "^org:[a-z0-9-]+$"
    },
    "label": { "type": "string" },
    "classification": {
      "type": "string",
      "enum": [
        "bewindspersoon",
        "abd-tmg",
        "abd-directeur",
        "abd-afdelingshoofd",
        "abd-projectleider",
        "gemeentesecretaris",
        "provinciesecretaris",
        "kamerlid",
        "statenlid",
        "raadslid",
        "commissaris-vd-koning",
        "gedeputeerde",
        "wethouder",
        "burgemeester",
        "dijkgraaf",
        "db-waterschap",
        "ab-waterschap",
        "voorzitter-hcs",
        "lid-hcs",
        "rvb-zbo",
        "rechter",
        "officier-van-justitie",
        "gezaghebber",
        "griffier",
        "overig"
      ]
    },
    "seat_count": {
      "oneOf": [
        { "type": "integer", "minimum": 1 },
        { "type": "null" }
      ]
    },
    "valid_from": { "type": "string", "format": "date" },
    "valid_until": {
      "oneOf": [
        { "type": "string", "format": "date" },
        { "type": "null" }
      ]
    },
    "roo_functie_id": {
      "type": "string",
      "description": "ROO <functie systeemId>: link naar het functie-record in ROO."
    },
    "roo_naam": {
      "type": "string",
      "description": "ROO <functie><naam>: officiële functie-naam zoals ROO die hanteert. Mag afwijken van polder's `label` (polder gebruikt vaak een korter, gestandaardiseerd label)."
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "url", "retrieved"],
        "properties": {
          "id": { "type": "string" },
          "url": { "type": "string", "format": "uri" },
          "retrieved": { "type": "string", "format": "date" },
          "fields": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      },
      "description": "Optioneel: per-veld provenance. Posts hadden voorheen geen sources omdat ze afgeleid zijn uit mandaten en organisaties; sinds Phase 3 schrijft de ROO-resolver hier `roo`-entries in voor `roo_functie_id`/`roo_naam`."
    }
  }
}
