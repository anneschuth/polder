---
import Base from '~/layouts/Base.astro';
import '~/styles/organogram.css';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const dataBase = `${base}/organogram/data`;
---
<Base title="Organogram" description="Interactief organogram van de Nederlandse overheid">
  <Fragment slot="head">
    <meta name="organogram-data-base" content={dataBase} />
  </Fragment>

  <article class="stack">
    <h1>Organogram</h1>
    <p class="muted">
      Interactieve boomweergave van organisaties, onderdelen en bestuurders.
      Klik om in te zoomen, sleep om te pannen. Klik op een persoon om naar het
      detailrecord te gaan.
    </p>
    <div class="organogram-controls">
      <div class="search-wrap">
        <input id="search" type="search" placeholder="Zoek organisatie of persoon…" autocomplete="off" />
        <div id="search-results" class="search-results" hidden></div>
      </div>
      <div id="timebar">
        <input id="timeslider" type="range" />
        <output id="timelabel">vandaag</output>
      </div>
    </div>
  </article>

  <section class="organogram-canvas" slot="after-main" data-theme="light">
    <div id="chart" aria-label="Organogram"></div>
    <aside id="breadcrumb" aria-live="polite"></aside>
  </section>

  <script is:inline src={`${base}/organogram-vendor/d3.v7.min.js`}></script>
  <script is:inline src={`${base}/organogram-vendor/fuse.min.js`}></script>
  <script is:inline type="module" src={`${base}/organogram/js/main.js`}></script>
</Base>

<style is:global>
  .organogram-controls {
    display: flex;
    gap: 1rem;
    align-items: center;
    flex-wrap: wrap;
  }
  .organogram-controls .search-wrap {
    flex: 1;
    min-width: 16rem;
    max-width: 32rem;
    position: relative;
  }
  .organogram-controls input[type="search"] {
    width: 100%;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--primitives-color-coolgray-200, #b7c0cc);
    border-radius: 4px;
    font: inherit;
    background: #fff;
    color: inherit;
  }
  .organogram-controls .search-results {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: #fff;
    border: 1px solid var(--primitives-color-coolgray-200, #b7c0cc);
    border-top: none;
    max-height: 24rem;
    overflow-y: auto;
    z-index: 10;
  }
  .organogram-controls #timebar {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex: 1;
    min-width: 14rem;
  }
  .organogram-controls #timeslider {
    flex: 1;
    accent-color: var(--primitives-color-lintblauw-500, #0058a3);
  }
  .organogram-controls #timelabel {
    min-width: 4rem;
    font-variant-numeric: tabular-nums;
    color: var(--semantics-content-secondary-color, #555);
  }

  /* Canvas is a sibling of <main> — already full-bleed by virtue of not
     being inside the 72rem-capped main. */
  .organogram-canvas {
    position: relative;
    height: 75vh;
    overflow: hidden;
    background: var(--semantics-surfaces-background-color, #fff);
    border-top: 1px solid var(--primitives-color-coolgray-100, #d9dee5);
    border-bottom: 1px solid var(--primitives-color-coolgray-100, #d9dee5);
  }
  .organogram-canvas #chart {
    width: 100%;
    height: 100%;
  }
  .organogram-canvas #breadcrumb {
    position: absolute;
    bottom: 0;
    left: 0;
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
    color: var(--semantics-content-secondary-color, #555);
    background: color-mix(in srgb, var(--semantics-surfaces-background-color, #fff) 85%, transparent);
    pointer-events: none;
  }
</style>
