---
import Base from '~/layouts/Base.astro';
import Card from '~/components/Card.astro';
import Badge from '~/components/Badge.astro';
import SourceList from '~/components/SourceList.astro';
import EditLink from '~/components/EditLink.astro';
import {
  loadAll,
  currentName,
  orgUrl,
  postUrl,
  personUrl,
  personDisplayName,
  isMandateCurrent,
  orgAccent,
  editUrl,
  type Post,
} from '~/lib/data';

export async function getStaticPaths() {
  const { posts } = loadAll();
  return posts.map((p) => ({
    params: { slug: p.slug },
    props: { post: p },
  }));
}

interface Props {
  post: Post;
}

const { post } = Astro.props;
const edit = (fieldPath: string) => editUrl(post, fieldPath);
const data = loadAll();
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const org = data.orgById.get(post.organization_id);
const accent = orgAccent(org?.type);
const mandates = (data.mandatesByPost.get(post.id) ?? []).slice().sort((a, b) => {
  const ac = isMandateCurrent(a.mandate) ? 0 : 1;
  const bc = isMandateCurrent(b.mandate) ? 0 : 1;
  return ac - bc || (b.mandate.start_date ?? '').localeCompare(a.mandate.start_date ?? '');
});
const current = mandates.filter((m) => isMandateCurrent(m.mandate));
const historical = mandates.filter((m) => !isMandateCurrent(m.mandate));
const siblingPosts = (data.postsByOrg.get(post.organization_id) ?? [])
  .filter((p) => p.id !== post.id)
  .sort((a, b) => a.label.localeCompare(b.label, 'nl'));

const ICON_INFO = 'info-circle';
const ICON_USER = 'person';
const ICON_CLOCK = 'history';
const ICON_BRIEFCASE = 'business-suitcase';
---
<Base title={post.label}>
  <article class="stack">
    <header class="stack">
      <p class="muted">
        Post
        {org && <> bij <a href={orgUrl(org, base)}>{currentName(org)}</a></>}
        · <code>{post.id}</code>
      </p>
      <h1>{post.label}<EditLink href={edit('label')} /></h1>
    </header>

    <div class="sections">
      <Card title="Kerngegevens" icon={ICON_INFO} accent={accent}>
        <div class="stack">
          {post.classification && (
            <div class="badge-row editable"><Badge label={post.classification} tone="lint" /><EditLink href={edit('classification')} /></div>
          )}
          <dl class="deflist">
            {org && (
              <div><dt class="muted">Organisatie</dt><dd><a href={orgUrl(org, base)}>{currentName(org)}</a></dd></div>
            )}
            {post.seat_count != null && (
              <div><dt class="muted">Aantal zetels</dt><dd>{post.seat_count}<EditLink href={edit('seat_count')} /></dd></div>
            )}
            {post.valid_from && (
              <div><dt class="muted">Geldig vanaf</dt><dd>{post.valid_from}<EditLink href={edit('valid_from')} /></dd></div>
            )}
            {post.valid_until && (
              <div><dt class="muted">Geldig tot</dt><dd>{post.valid_until}<EditLink href={edit('valid_until')} /></dd></div>
            )}
            {post.roo_functie_id && (
              <div><dt class="muted">ROO-functie-id</dt><dd><code>{post.roo_functie_id}</code><EditLink href={edit('roo_functie_id')} /></dd></div>
            )}
            {post.roo_naam && post.roo_naam !== post.label && (
              <div><dt class="muted">ROO-naam</dt><dd>{post.roo_naam}<EditLink href={edit('roo_naam')} /></dd></div>
            )}
          </dl>
        </div>
      </Card>

      {current.length > 0 && (
        <Card title={`Huidige bezetter${current.length > 1 ? 's' : ''} (${current.length})`} icon={ICON_USER} accent={accent}>
          <nldd-list>
            {current.map(({ person, mandate }) => {
              const meta = [
                mandate.start_date ? `sinds ${mandate.start_date}` : null,
                mandate.role && mandate.role !== post.label ? `rol: ${mandate.role}` : null,
              ].filter(Boolean).join(' · ');
              return (
                <nldd-list-item href={personUrl(person.slug, base)}>
                  <nldd-title-cell
                    size={5}
                    text={personDisplayName(person)}
                    supporting-text={meta || undefined}
                  ></nldd-title-cell>
                </nldd-list-item>
              );
            })}
          </nldd-list>
        </Card>
      )}

      {siblingPosts.length > 0 && (
        <Card title="Verwante posten" icon={ICON_BRIEFCASE} accent={accent} collapsible open={siblingPosts.length <= 15}>
          <nldd-list>
            {siblingPosts.map((p) => (
              <nldd-list-item href={postUrl(p.slug, base)}>
                <nldd-title-cell
                  size={5}
                  text={p.label}
                  supporting-text={p.classification || undefined}
                ></nldd-title-cell>
              </nldd-list-item>
            ))}
          </nldd-list>
        </Card>
      )}
      {historical.length > 0 && (
        <Card title={`Eerdere bezetters (${historical.length})`} icon={ICON_CLOCK} accent={accent} collapsible open={historical.length <= 20}>
          <table class="data">
            <thead>
              <tr><th>Persoon</th><th>Periode</th></tr>
            </thead>
            <tbody>
              {historical.map(({ person, mandate }) => (
                <tr>
                  <td><a href={personUrl(person.slug, base)}>{personDisplayName(person)}</a></td>
                  <td>{mandate.start_date ?? '?'} – {mandate.end_date ?? '?'}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </Card>
      )}
    </div>

    <SourceList sources={post.sources} editFor={edit} />
  </article>
</Base>
