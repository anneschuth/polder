---
import Base from '~/layouts/Base.astro';
import Card from '~/components/Card.astro';
import Badge from '~/components/Badge.astro';
import Identifiers from '~/components/Identifiers.astro';
import Contact from '~/components/Contact.astro';
import GeoCouncil from '~/components/GeoCouncil.astro';
import WooCard from '~/components/WooCard.astro';
import RelationsCard from '~/components/RelationsCard.astro';
import SourceList from '~/components/SourceList.astro';
import EditLink from '~/components/EditLink.astro';
import {
  loadAll,
  currentName,
  currentAbbr,
  orgUrl,
  postUrl,
  personUrl,
  personDisplayName,
  isMandateCurrent,
  siblingOrgs,
  peopleByPostOfOrg,
  asIdArray,
  orgAccent,
  editUrl,
  type Organization,
} from '~/lib/data';

export async function getStaticPaths() {
  const { orgs } = loadAll();
  return orgs.map((o) => ({
    params: { type: o.type, slug: o.slug },
    props: { org: o },
  }));
}

interface Props {
  org: Organization;
}

const { org } = Astro.props;
const edit = (fieldPath: string) => editUrl(org, fieldPath);
const data = loadAll();
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const parent = org.parent_id ? data.orgById.get(org.parent_id) : null;
const children = (data.childrenByOrg.get(org.id) ?? [])
  .slice()
  .sort((a, b) => currentName(a).localeCompare(currentName(b), 'nl'));
const siblings = siblingOrgs(org, data);
const predecessors = asIdArray(org.predecessor_id).map((id) => ({ id, org: data.orgById.get(id) }));
const successors = asIdArray(org.successor_id).map((id) => ({ id, org: data.orgById.get(id) }));
const posts = (data.postsByOrg.get(org.id) ?? [])
  .slice()
  .sort((a, b) => a.label.localeCompare(b.label, 'nl'));
const mandates = (data.mandatesByOrg.get(org.id) ?? []).slice().sort((a, b) => {
  const ac = isMandateCurrent(a.mandate) ? 0 : 1;
  const bc = isMandateCurrent(b.mandate) ? 0 : 1;
  return ac - bc || (b.mandate.start_date ?? '').localeCompare(a.mandate.start_date ?? '');
});
const currentMandates = mandates.filter((m) => isMandateCurrent(m.mandate));
const postGroups = peopleByPostOfOrg(org, data);
const name = currentName(org);
const abbr = currentAbbr(org);
const accent = orgAccent(org.type);
const nameHistory = (org.names ?? []).length > 1 ? org.names : [];

const policyAreas = org.policy_areas ?? [];
const grondslagen = org.wettelijke_grondslagen ?? [];
const evaluations = org.evaluations ?? [];
const hasBeleid = policyAreas.length > 0 || grondslagen.length > 0 || evaluations.length > 0;
const rtm = org.relation_to_ministerie;

const hasRelations = Boolean(
  parent ||
    children.length ||
    siblings.length ||
    predecessors.length ||
    successors.length,
);
const c = org.contact ?? {};
const hasContact = Boolean(
  c.website ||
    c.email ||
    c.fax ||
    c.addresses?.length ||
    c.phones?.length ||
    c.emails?.length ||
    c.internet_addresses?.length ||
    c.contact_forms?.length ||
    c.social_media?.length ||
    org.afspraak?.email ||
    org.afspraak?.telefoonnummer ||
    org.afspraak?.url ||
    org.organogram_url,
);
const hasWoo = Boolean(
  org.woo?.wooInformatie?.urls?.url ||
    org.woo?.wooInformatie?.urls?.overzichtURL ||
    org.woo?.wooVerzoek?.url ||
    org.woo?.wooIndex?.documentLocatie?.length ||
    org.classifications?.length,
);
const hasIdentifiers = Boolean(
  Object.values(org.identifiers ?? {}).some((v) => v != null && v !== '') || rtm?.naam,
);

const ICON_INFO = 'info-circle';
const ICON_LINK = 'link';
const ICON_MAIL = 'envelope';
const ICON_MAP = 'building';
const ICON_DOC = 'document';
const ICON_ID = 'diploma';
const ICON_BRIEFCASE = 'business-suitcase';
const ICON_PEOPLE = 'users';
---
<Base title={name} description={`${name} (${org.type})`}>
  <article class="stack">
    <header class="stack">
      <p class="muted">
        {org.type}{org.subtype && <> · {org.subtype}</>}
        {parent && (
          <> · onderdeel van <a href={orgUrl(parent, base)}>{currentName(parent)}</a></>
        )}
        · <code>{org.id}</code>
      </p>
      <h1>{name}{abbr && <span class="muted"> ({abbr})</span>}<EditLink href={edit('names')} /></h1>
      {org.description?.text && (
        <p class="lede">
          {org.description.text}
          {org.description.url && (
            <> <a href={org.description.url} rel="external">↗</a></>
          )}
          <EditLink href={edit('description')} />
        </p>
      )}
    </header>

    <div class="sections">
      <Card title="Kerngegevens" icon={ICON_INFO} accent={accent}>
        <dl class="deflist">
          {org.classification && (
            <div><dt class="muted">Classificatie</dt><dd>{org.classification}<EditLink href={edit('classification')} /></dd></div>
          )}
          {org.legal_form && (
            <div><dt class="muted">Rechtsvorm</dt><dd>{org.legal_form}<EditLink href={edit('legal_form')} /></dd></div>
          )}
          {org.zbo_kind && (
            <div><dt class="muted">Soort ZBO</dt><dd>{org.zbo_kind}<EditLink href={edit('zbo_kind')} /></dd></div>
          )}
          {org.advisory_kind && (
            <div><dt class="muted">Soort adviescollege</dt><dd>{org.advisory_kind}<EditLink href={edit('advisory_kind')} /></dd></div>
          )}
          {org.subname && (
            <div><dt class="muted">Subnaam</dt><dd>{org.subname}<EditLink href={edit('subname')} /></dd></div>
          )}
          {org.valid_from && (
            <div><dt class="muted">Geldig vanaf</dt><dd>{org.valid_from}<EditLink href={edit('valid_from')} /></dd></div>
          )}
          {org.valid_until && (
            <div><dt class="muted">Geldig tot</dt><dd>{org.valid_until}<EditLink href={edit('valid_until')} /></dd></div>
          )}
          {org.last_mutation && (
            <div><dt class="muted">Laatste mutatie</dt><dd>{org.last_mutation}<EditLink href={edit('last_mutation')} /></dd></div>
          )}
          {org.last_verified && (
            <div><dt class="muted">Laatst geverifieerd</dt><dd>{org.last_verified}<EditLink href={edit('last_verified')} /></dd></div>
          )}
          {org.contact?.website && (
            <div>
              <dt class="muted">Website</dt>
              <dd><a href={org.contact.website} rel="external">{org.contact.website.replace(/^https?:\/\//, '')}</a><EditLink href={edit('contact.website')} /></dd>
            </div>
          )}
        </dl>
        {nameHistory.length > 0 && (
          <details>
            <summary>Naamhistorie ({nameHistory.length})</summary>
            <nldd-list>
              {nameHistory.map((n) => (
                <nldd-list-item>
                  <nldd-title-cell
                    size={5}
                    text={n.abbr ? `${n.value} (${n.abbr})` : n.value}
                    supporting-text={`${n.valid_from ?? '?'} – ${n.valid_until ?? 'heden'}`}
                  ></nldd-title-cell>
                </nldd-list-item>
              ))}
            </nldd-list>
          </details>
        )}
      </Card>

      {hasRelations && (
        <Card title="Relaties" icon={ICON_LINK} accent={accent}>
          <RelationsCard
            parent={parent}
            children={children}
            siblings={siblings}
            predecessors={predecessors}
            successors={successors}
          />
        </Card>
      )}

      {hasContact && (
        <Card title="Contact" icon={ICON_MAIL} accent={accent}>
          <Contact contact={org.contact} afspraak={org.afspraak} organogram_url={org.organogram_url} />
        </Card>
      )}

      {(org.geography || org.council) && (
        <Card title="Geografie & raad" icon={ICON_MAP} accent={accent}>
          <GeoCouncil geography={org.geography} council={org.council} />
        </Card>
      )}

      {hasWoo && (
        <Card title="Woo & classificaties" icon={ICON_DOC} accent={accent}>
          <WooCard woo={org.woo} classifications={org.classifications} />
        </Card>
      )}

      {hasBeleid && (
        <Card title="Beleid & grondslag" icon={ICON_DOC} accent={accent}>
          <div class="stack">
            {policyAreas.length > 0 && (
              <div>
                <p class="muted" style="margin:0 0 .35rem;">Beleidsterreinen</p>
                <div class="badge-row">
                  {policyAreas.map((p) => <Badge label={p.naam ?? ''} href={p.tooi} />)}
                </div>
              </div>
            )}
            {grondslagen.length > 0 && (
              <div>
                <p class="muted" style="margin:0 0 .35rem;">Wettelijke grondslagen</p>
                <nldd-list>
                  {grondslagen.map((g) => (
                    <nldd-list-item href={g.referentie || undefined}>
                      <nldd-title-cell
                        size={5}
                        text={g.opschrift ?? g.referentie}
                      ></nldd-title-cell>
                    </nldd-list-item>
                  ))}
                </nldd-list>
              </div>
            )}
            {evaluations.length > 0 && (
              <div>
                <p class="muted" style="margin:0 0 .35rem;">Evaluaties</p>
                <nldd-list>
                  {evaluations.map((e) => (
                    <nldd-list-item href={e.referentie || undefined}>
                      <nldd-title-cell
                        size={5}
                        text={e.naam_rapport ?? e.kamerstuknummer ?? e.datum}
                        supporting-text={e.datum || undefined}
                      ></nldd-title-cell>
                    </nldd-list-item>
                  ))}
                </nldd-list>
              </div>
            )}
          </div>
        </Card>
      )}

      {hasIdentifiers && (
        <Card title="Identifiers" icon={ICON_ID} accent={accent}>
          <Identifiers identifiers={org.identifiers} kind="org" editFor={edit} />
          {rtm?.naam && (
            <p style="margin-top:.75rem;">
              <span class="muted">Hoort bij ministerie</span><br />
              {rtm.org_id && data.orgById.get(rtm.org_id) ? (
                <a href={orgUrl(data.orgById.get(rtm.org_id)!, base)}>{rtm.naam}</a>
              ) : (
                rtm.naam
              )}
            </p>
          )}
        </Card>
      )}

      {posts.length > 0 && (
        <Card title={`Posten (${posts.length})`} icon={ICON_BRIEFCASE} accent={accent}>
          <nldd-list>
            {posts.map((p) => (
              <nldd-list-item href={postUrl(p.slug, base)}>
                <nldd-title-cell
                  size={5}
                  text={p.label}
                  supporting-text={p.classification || undefined}
                ></nldd-title-cell>
              </nldd-list-item>
            ))}
          </nldd-list>
        </Card>
      )}

      {postGroups.length > 0 && (
        <Card title="Mensen via posten" icon={ICON_PEOPLE} accent={accent}>
          <div class="stack">
            {postGroups.map(({ post, entries }) => (
              <nldd-list>
                <p slot="header" style="margin:0;">
                  <a href={postUrl(post.slug, base)}><strong>{post.label}</strong></a>
                  <span class="muted"> · {entries.filter((e) => isMandateCurrent(e.mandate)).length} lopend</span>
                </p>
                {entries.slice(0, 50).map(({ person, mandate }) => (
                  <nldd-list-item href={personUrl(person.slug, base)}>
                    <nldd-title-cell
                      size={5}
                      text={personDisplayName(person)}
                      supporting-text={`${mandate.start_date ?? '?'} – ${mandate.end_date ?? 'heden'}`}
                    ></nldd-title-cell>
                  </nldd-list-item>
                ))}
                {entries.length > 50 && (
                  <p slot="footer" class="muted">Eerste 50 van {entries.length} getoond.</p>
                )}
              </nldd-list>
            ))}
          </div>
        </Card>
      )}

      {mandates.length > 0 && (
        <Card
          title={`Directe mandaten (${mandates.length}, ${currentMandates.length} lopend)`}
          icon={ICON_PEOPLE}
          accent={accent}
          collapsible
        >
          <table class="data">
            <thead>
              <tr><th>Persoon</th><th>Rol</th><th>Periode</th></tr>
            </thead>
            <tbody>
              {mandates.slice(0, 200).map(({ person, mandate }) => (
                <tr>
                  <td><a href={personUrl(person.slug, base)}>{personDisplayName(person)}</a></td>
                  <td>{mandate.role}{isMandateCurrent(mandate) && <> <small class="muted">(lopend)</small></>}</td>
                  <td>{mandate.start_date ?? '?'} – {mandate.end_date ?? 'heden'}</td>
                </tr>
              ))}
            </tbody>
          </table>
          {mandates.length > 200 && (
            <p class="muted">Eerste 200 van {mandates.length} mandaten getoond.</p>
          )}
        </Card>
      )}
    </div>

    <SourceList sources={org.sources} editFor={edit} />
  </article>
</Base>
