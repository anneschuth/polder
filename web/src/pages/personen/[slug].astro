---
import Base from '~/layouts/Base.astro';
import Card from '~/components/Card.astro';
import Timeline from '~/components/Timeline.astro';
import MandaatTimeline from '~/components/MandaatTimeline.astro';
import Identifiers from '~/components/Identifiers.astro';
import SourceList from '~/components/SourceList.astro';
import {
  loadAll,
  personDisplayName,
  careerSummary,
  personExternalLinks,
  currentName,
  orgUrl,
  postUrl,
  isMandateCurrent,
  sortedMandates,
  type Person,
} from '~/lib/data';

export async function getStaticPaths() {
  const { people } = loadAll();
  return people.map((p) => ({
    params: { slug: p.slug },
    props: { person: p },
  }));
}

interface Props {
  person: Person;
}

const { person } = Astro.props;
const data = loadAll();
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const name = personDisplayName(person);
const honorifics = (person.name?.honorifics_pre ?? []).join(' ');
const honorificsPost = (person.name?.honorifics_post ?? []).join(' ');
const externals = personExternalLinks(person);
const career = careerSummary(person);

const allMandaten = sortedMandates(person.mandaten ?? []);
const current = allMandaten.filter((m) => isMandateCurrent(m));

const hasIdentifiers = Object.values(person.identifiers ?? {}).some(
  (v) => v != null && v !== '',
);

const GENDER: Record<string, string> = { m: 'man', f: 'vrouw', x: 'anders' };

const ICON_USER = 'person';
const ICON_CLOCK = 'history';
const ICON_TABLE = 'list';
const ICON_ID = 'diploma';
---
<Base title={name} description={`Polder-record voor ${name}`}>
  <article class="stack">
    <header class="stack">
      <p class="muted">Persoon · <code>{person.id}</code></p>
      <h1>
        {honorifics && <span class="muted">{honorifics} </span>}{name}
        {honorificsPost && <span class="muted"> {honorificsPost}</span>}
      </h1>
      {career && <p class="career">{career}</p>}
      {externals.length > 0 && (
        <p class="badge-row">
          {externals.map((e) => (
            <nldd-link
              href={e.url}
              text={e.label}
              size="sm"
              end-icon="external-link"
              target="_blank"
            ></nldd-link>
          ))}
        </p>
      )}
    </header>

    <div class="sections">
      {current.length > 0 && (
        <Card title="Huidige functie(s)" icon={ICON_USER}>
          <nldd-list>
            {current.map((m) => {
              const org = data.orgById.get(m.organization_id);
              const post = m.post_id ? data.postById.get(m.post_id) : null;
              return (
                <nldd-list-item>
                  <nldd-title-cell size={5}>
                    <span>
                      <strong>{m.role ?? post?.label ?? 'Mandaat'}</strong>
                      {org && <> · <a href={orgUrl(org, base)}>{currentName(org)}</a></>}
                      {post && <> · <a href={postUrl(post.slug, base)}>{post.label}</a></>}
                    </span>
                    {m.start_date && (
                      <span slot="supporting-text">sinds {m.start_date}</span>
                    )}
                  </nldd-title-cell>
                </nldd-list-item>
              );
            })}
          </nldd-list>
        </Card>
      )}

      <Card title="Persoonsgegevens" icon={ICON_USER}>
        <dl class="deflist">
          {person.birth?.year && (
            <div><dt class="muted">Geboortejaar</dt><dd>{person.birth.year}</dd></div>
          )}
          {person.gender && (
            <div><dt class="muted">Geslacht</dt><dd>{GENDER[person.gender] ?? person.gender}</dd></div>
          )}
          {person.name?.family && (
            <div><dt class="muted">Familienaam</dt><dd>{person.name.family}</dd></div>
          )}
          {person.name?.given && (
            <div><dt class="muted">Voornaam</dt><dd>{person.name.given}</dd></div>
          )}
          {person.name?.tussenvoegsel && (
            <div><dt class="muted">Tussenvoegsel</dt><dd>{person.name.tussenvoegsel}</dd></div>
          )}
          {person.name?.initials && (
            <div><dt class="muted">Initialen</dt><dd>{person.name.initials}</dd></div>
          )}
        </dl>
      </Card>

      {hasIdentifiers && (
        <Card title="Identifiers" icon={ICON_ID}>
          <Identifiers identifiers={person.identifiers} kind="person" />
        </Card>
      )}

      <Card title="Loopbaan" icon={ICON_CLOCK}>
        <Timeline mandaten={person.mandaten ?? []} />
      </Card>

      {allMandaten.length > 0 && (
        <Card title="Mandaten (tabel)" icon={ICON_TABLE} collapsible>
          <MandaatTimeline mandaten={person.mandaten ?? []} />
        </Card>
      )}
    </div>

    <SourceList sources={person.sources} />
  </article>
</Base>
