---
import {
  loadAll,
  sortedMandates,
  currentName,
  currentAbbr,
  orgUrl,
  postUrl,
  orgAccent,
  type Mandate,
} from '~/lib/data';

interface Props {
  mandaten: Mandate[];
  max?: number;
}

const { mandaten, max = 200 } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const data = loadAll();
const sorted = sortedMandates(mandaten ?? []).slice(0, max);
const total = (mandaten ?? []).length;

const nowYear = new Date().getFullYear();
const year = (d?: string | null): number | null => {
  if (!d) return null;
  const n = Number(d.slice(0, 4));
  return Number.isFinite(n) ? n : null;
};

const starts = sorted.map((m) => year(m.start_date)).filter((n): n is number => n != null);
const ends = sorted.map((m) => year(m.end_date) ?? nowYear);
let minY = starts.length ? Math.min(...starts) : nowYear - 1;
let maxY = Math.max(nowYear, ...ends);
if (maxY <= minY) maxY = minY + 1;
const spanY = maxY - minY;

const axisYears = [minY, minY + Math.round(spanY / 2), maxY];

const pct = (y: number) => ((y - minY) / spanY) * 100;
---

{sorted.length === 0 ? (
  <p class="muted">Geen mandaten bekend.</p>
) : (
  <div class="tl">
    <div class="tl-axis">
      {axisYears.map((y) => <span>{y}</span>)}
    </div>
    {sorted.map((m) => {
      const org = data.orgById.get(m.organization_id);
      const post = m.post_id ? data.postById.get(m.post_id) : null;
      const isCurrent = !m.end_date;
      const sy = year(m.start_date) ?? minY;
      const ey = year(m.end_date) ?? nowYear;
      const left = Math.max(0, pct(sy));
      const width = Math.max(2, pct(Math.max(ey, sy + 1)) - left);
      const accent = orgAccent(org?.type);
      const period = `${m.start_date ?? '?'} – ${m.end_date ?? 'heden'}`;
      return (
        <div class="tl-row">
          <div class="tl-track">
            <span
              class={`tl-bar${isCurrent ? ' tl-bar--current' : ''}`}
              style={`left:${left}%;width:${width}%;--bar-accent:${accent};`}
              title={period}
            ></span>
          </div>
          <div class="tl-label">
            <strong>{m.role ?? post?.label ?? 'Mandaat'}</strong>
            {org && (
              <a href={orgUrl(org, base)}>
                {currentName(org)}
                {currentAbbr(org) && <span class="muted"> ({currentAbbr(org)})</span>}
              </a>
            )}
            {post && <a href={postUrl(post.slug, base)}>· {post.label}</a>}
            <span class="tl-period">{period}{isCurrent && ' · lopend'}</span>
          </div>
        </div>
      );
    })}
    {total > max && <p class="muted">Eerste {max} van {total} mandaten getoond.</p>}
  </div>
)}
