---
import type { Source } from '~/lib/data';

interface Props {
  sources?: Source[];
}

const { sources } = Astro.props;

const meta = (s: Source) => {
  const parts: string[] = [];
  if (s.retrieved) parts.push(`opgehaald ${s.retrieved}`);
  if (s.fields && s.fields.length > 0) parts.push(`velden: ${s.fields.join(', ')}`);
  return parts.join(' · ');
};
---
{(sources ?? []).length > 0 && (
  <section>
    <h2>Bronnen</h2>
    <nldd-list>
      {(sources ?? []).map((s) => (
        <nldd-list-item href={s.url || undefined}>
          <nldd-text-cell
            size="sm"
            text={s.id}
            supporting-text={meta(s) || undefined}
          ></nldd-text-cell>
        </nldd-list-item>
      ))}
    </nldd-list>
  </section>
)}
