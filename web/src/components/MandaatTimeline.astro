---
import { loadAll, sortedMandates, currentName, currentAbbr, orgUrl, postUrl, type Mandate } from '~/lib/data';
import EditLink from '~/components/EditLink.astro';

interface Props {
  mandaten: Mandate[];
  /** Optioneel: veldpad → GitHub-edit-URL. Toont per rij een edit-icoon. */
  editFor?: (fieldPath: string) => string | undefined;
}

const { mandaten, editFor } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const data = loadAll();
const orig = mandaten ?? [];
const sorted = sortedMandates(orig);
// Originele YAML-positie op object-identiteit (ids kunnen dubbel zijn).
const mandatePath = (m: Mandate) => {
  const i = orig.indexOf(m);
  return i >= 0 ? `mandaten[${i}]` : '';
};
---
{sorted.length === 0 ? (
  <p class="muted">Geen mandaten bekend.</p>
) : (
  <table class="data">
    <thead>
      <tr>
        <th>Rol</th>
        <th>Organisatie</th>
        <th>Post</th>
        <th>Periode</th>
        <th>Benoeming</th>
      </tr>
    </thead>
    <tbody>
      {sorted.map((m) => {
        const org = data.orgById.get(m.organization_id);
        const post = m.post_id ? data.postById.get(m.post_id) : null;
        const isCurrent = !m.end_date;
        const period = `${m.start_date ?? '?'} – ${m.end_date ?? 'heden'}`;
        const ap = m.appointment;
        return (
          <tr>
            <td>
              {m.role}
              {isCurrent && <> <small class="muted">(lopend)</small></>}
            </td>
            <td>
              {org ? (
                <a href={orgUrl(org, base)}>
                  {currentName(org)}
                  {currentAbbr(org) && <span class="muted"> ({currentAbbr(org)})</span>}
                </a>
              ) : (
                <span class="muted">{m.organization_id}</span>
              )}
            </td>
            <td>
              {post ? (
                <a href={postUrl(post.slug, base)}>{post.label}</a>
              ) : m.post_id ? (
                <span class="muted">{m.post_id}</span>
              ) : null}
            </td>
            <td>{period}</td>
            <td>
              {ap ? (
                <>
                  {ap.decision && <span>{ap.decision}</span>}
                  {ap.kb_nummer && <span class="muted"> · {ap.kb_nummer}</span>}
                  {ap.staatscourant_url && (
                    <> · <a href={ap.staatscourant_url} rel="external">Staatscourant</a></>
                  )}
                </>
              ) : (
                <span class="muted">–</span>
              )}
              {editFor && <EditLink href={editFor(mandatePath(m))} />}
            </td>
          </tr>
        );
      })}
    </tbody>
  </table>
)}
