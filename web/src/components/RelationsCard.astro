---
import OrgLink from '~/components/OrgLink.astro';
import type { Organization } from '~/lib/data';

interface Props {
  parent?: Organization | null;
  children?: Organization[];
  siblings?: Organization[];
  predecessors?: { id: string; org: Organization | undefined }[];
  successors?: { id: string; org: Organization | undefined }[];
}

const {
  parent,
  children = [],
  siblings = [],
  predecessors = [],
  successors = [],
} = Astro.props;

const hasAny = Boolean(
  parent ||
    children.length ||
    siblings.length ||
    predecessors.length ||
    successors.length,
);
---

{hasAny && (
  <div class="stack">
    {parent && (
      <p><span class="muted">Onderdeel van</span><br /><OrgLink org={parent} /></p>
    )}
    {predecessors.length > 0 && (
      <p>
        <span class="muted">Voorganger(s)</span><br />
        {predecessors.map((it, i) => (
          <>{i > 0 && ', '}<OrgLink org={it.org} fallbackId={it.id} /></>
        ))}
      </p>
    )}
    {successors.length > 0 && (
      <p>
        <span class="muted">Opvolger(s)</span><br />
        {successors.map((it, i) => (
          <>{i > 0 && ', '}<OrgLink org={it.org} fallbackId={it.id} /></>
        ))}
      </p>
    )}
    {siblings.length > 0 && (
      <details open={siblings.length <= 12}>
        <summary>Zusterorganisaties ({siblings.length})</summary>
        <nldd-list>
          {siblings.map((s) => (
            <nldd-list-item>
              <nldd-title-cell size={5}>
                <span><OrgLink org={s} /></span>
                <span slot="supporting-text">{s.type}</span>
              </nldd-title-cell>
            </nldd-list-item>
          ))}
        </nldd-list>
      </details>
    )}
    {children.length > 0 && (
      <details open={children.length <= 20}>
        <summary>Onderdelen ({children.length})</summary>
        <nldd-list>
          {children.map((c) => (
            <nldd-list-item>
              <nldd-title-cell size={5}>
                <span><OrgLink org={c} /></span>
                <span slot="supporting-text">{c.type}</span>
              </nldd-title-cell>
            </nldd-list-item>
          ))}
        </nldd-list>
      </details>
    )}
  </div>
)}
