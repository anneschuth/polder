---
import '@nldd/design-system/styles';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<!doctype html>
<html lang="nl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · Polder</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" href={`${base}/favicon.svg`} type="image/svg+xml" />
    <ClientRouter />
    <slot name="head" />
  </head>
  <body>
    <nldd-app-view background="default">
      <nldd-page>
        <nldd-top-navigation-bar
          slot="header"
          logo-title="Polder"
          logo-subtitle="Publieke Overheid: Leden, Dienstverbanden, Eenheden, Rollen"
          logo-href={`${base}/`}
        >
          <nldd-menu-bar-item
            slot="global"
            href={`${base}/personen/`}
            text="Personen"
          ></nldd-menu-bar-item>
          <nldd-menu-bar-item
            slot="global"
            href={`${base}/organisaties/`}
            text="Organisaties"
          ></nldd-menu-bar-item>
          <nldd-menu-bar-item
            slot="global"
            href={`${base}/posten/`}
            text="Posten"
          ></nldd-menu-bar-item>
          <nldd-menu-bar-item
            slot="global"
            href={`${base}/stats/`}
            text="Statistieken"
          ></nldd-menu-bar-item>
          <nldd-menu-bar-item
            slot="global"
            href={`${base}/organogram/`}
            text="Organogram"
          ></nldd-menu-bar-item>
        </nldd-top-navigation-bar>
        <main>
          <slot />
        </main>
        <slot name="after-main" />
      </nldd-page>
    </nldd-app-view>

    <script>
      import '@nldd/design-system';
    </script>

    <style is:global>
      /* NLDD ships its own @font-face with font-display: swap. We rely on
         the preload <link> in <head> to put the regular weight in cache
         before first paint, which eliminates the FOUT on initial load.
         For subsequent navigation, the View Transitions router keeps the
         DOM live so fonts are never re-fetched. */
      :root {
        color-scheme: light;
      }
      html, body {
        margin: 0;
        padding: 0;
        min-height: 100%;
      }
      body {
        font-family: RijksSans, system-ui, sans-serif;
        color: var(--semantics-content-color);
        background-color: var(--semantics-surfaces-background-color);
      }
      /* nldd-app-view is display:flex with height:100% — give it room.
         Using height:100vh + the internal nldd-page scroll keeps the
         top-nav fixed at the top while content scrolls underneath. */
      nldd-app-view {
        height: 100vh;
      }
      /* Force the global menu-bar to show even at narrow widths.
         Top-nav only renders global items when it has `.has-global-items`
         on the host or above a container-width threshold; we use the
         class hook so the links are visible. */
      nldd-top-navigation-bar {
        --_force-global: 1;
      }
      main {
        max-width: 72rem;
        margin: 0 auto;
        padding: 2rem 1.5rem 4rem;
        width: 100%;
        box-sizing: border-box;
      }
      a {
        color: inherit;
      }
      .grid {
        display: grid;
        gap: 1rem;
      }
      .grid-2 {
        grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
      }
      .muted {
        color: var(--semantics-content-secondary-color, #555);
      }

      /* ---- Section + definition-list layout ----
         No card boxes. One continuous page: each data block is a section
         with a heading + underline rule, followed by a dense label/value
         grid. Works for thin entities (no empty boxes) and rich ones alike. */
      .sections {
        display: flex;
        flex-direction: column;
        gap: 2.25rem;
      }
      .section > .section-head {
        margin: 0 0 0.9rem;
        font-size: 0.95rem;
        font-weight: 600;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--semantics-content-color);
      }
      .section > details > nldd-divider,
      .section > nldd-divider {
        margin: 0 0 1rem;
      }
      .section .card-icon {
        color: var(--card-accent, var(--primitives-color-accent-500));
        flex: none;
        display: inline-flex;
        width: 1.15rem;
        height: 1.15rem;
      }
      .section .card-icon svg {
        width: 100%;
        height: 100%;
      }
      .section > details > summary {
        cursor: pointer;
        color: var(--semantics-content-secondary-color);
        margin-bottom: 0.5rem;
      }
      /* Dense label/value grid. Label is a fixed muted column, value next to
         it. Auto-fills 2-3 columns on wide screens, 1 on narrow. */
      .deflist {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(22rem, 1fr));
        gap: 0.55rem 2.5rem;
        align-items: baseline;
      }
      .deflist > div {
        display: grid;
        grid-template-columns: 10rem 1fr;
        gap: 0 1rem;
        align-items: baseline;
      }
      .deflist dt {
        color: var(--semantics-content-secondary-color);
        font-size: 0.9rem;
      }
      .deflist dd {
        margin: 0;
      }
      @media (max-width: 32rem) {
        .deflist > div {
          grid-template-columns: 1fr;
          gap: 0;
        }
      }
      /* Long URLs / codes wrap instead of overflowing. */
      .section a,
      .section code,
      .deflist dd {
        overflow-wrap: anywhere;
        word-break: break-word;
      }
      .lede {
        font-size: 1.05rem;
        line-height: 1.6;
        color: var(--semantics-content-secondary-color);
      }
      .career {
        font-size: 1.05rem;
        line-height: 1.5;
      }

      /* ---- Chips: <nldd-tag>, optionally wrapped in a link ---- */
      .badge-link {
        text-decoration: none;
        display: inline-flex;
      }
      .badge-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
        align-items: center;
      }
      .seat-legend {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
      }
      .seat-dot {
        width: 0.7rem;
        height: 0.7rem;
        border-radius: 999px;
        flex: none;
      }

      /* ---- Graphical mandate timeline ---- */
      .tl {
        display: flex;
        flex-direction: column;
        gap: 0.65rem;
      }
      .tl-axis {
        display: flex;
        justify-content: space-between;
        font-size: 0.75rem;
        color: var(--semantics-content-secondary-color);
        border-bottom: 1px solid var(--primitives-color-coolgray-100);
        padding-bottom: 0.2rem;
      }
      .tl-row {
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
      }
      .tl-track {
        position: relative;
        height: 1.5rem;
        background: var(--primitives-color-coolgray-50);
        border-radius: 4px;
        overflow: hidden;
      }
      .tl-bar {
        position: absolute;
        top: 0;
        bottom: 0;
        min-width: 3px;
        max-width: 100%;
        border-radius: 4px;
        background: var(--bar-accent, var(--primitives-color-accent-500));
        display: block;
      }
      .tl-bar--current {
        background-image: repeating-linear-gradient(
          45deg,
          color-mix(in srgb, var(--primitives-color-coolgray-0) 35%, transparent)
            0 6px,
          transparent 6px 12px
        );
      }
      .tl-label {
        font-size: 0.85rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
        align-items: baseline;
      }
      .tl-label .tl-period {
        color: var(--semantics-content-secondary-color);
      }
      .tl-legend {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem 1rem;
        margin-top: 0.5rem;
        padding-top: 0.6rem;
        font-size: 0.8rem;
        color: var(--semantics-content-secondary-color);
        border-top: 1px solid var(--primitives-color-coolgray-100);
      }
      @media (max-width: 40rem) {
        .tl-axis {
          display: none;
        }
        .tl-track {
          height: auto;
          background: none;
        }
        .tl-bar {
          position: static;
          width: auto !important;
          height: 0.5rem;
        }
      }
      /* ---- Seat bar (raad) ---- */
      .seatbar {
        display: flex;
        height: 1.6rem;
        border-radius: 4px;
        overflow: hidden;
        border: 1px solid var(--primitives-color-coolgray-200);
      }
      .seatbar > span {
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.7rem;
        color: var(--primitives-color-coolgray-0);
        white-space: nowrap;
        overflow: hidden;
      }
      .stat-row {
        display: flex;
        flex-wrap: wrap;
        gap: 1.5rem;
      }
      .stat .stat-num {
        font-size: 1.5rem;
        font-weight: 600;
      }
      .stat .stat-lbl {
        font-size: 0.8rem;
        color: var(--semantics-content-secondary-color);
      }
      .stack {
        display: flex;
        flex-direction: column;
        gap: 1rem;
      }
      table.data {
        width: 100%;
        border-collapse: collapse;
      }
      table.data th, table.data td {
        text-align: left;
        padding: 0.5rem 0.75rem;
        border-bottom: 1px solid #e5e5e5;
        vertical-align: top;
      }
      table.data th {
        font-weight: 600;
        background: #fafafa;
      }
    </style>

    <script>
      // The top-navigation-bar only shows global menu items when the host
      // has the `has-global-items` class (see top-navigation-bar.styles.js
      // selectors `:host(.has-global-items) &`). The class is normally
      // toggled by the component itself based on slotted content, but in
      // SSR-rendered Astro markup the slot-change can race the class
      // application — set it explicitly once the component is defined.
      customElements.whenDefined('nldd-top-navigation-bar').then(() => {
        for (const nav of document.querySelectorAll('nldd-top-navigation-bar')) {
          nav.classList.add('has-global-items');
        }
      });
    </script>
  </body>
</html>
