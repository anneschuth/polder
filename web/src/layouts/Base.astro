---
import '@nldd/design-system/styles';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<!doctype html>
<html lang="nl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · Polder</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" href={`${base}/favicon.svg`} type="image/svg+xml" />
    <ClientRouter />
    <slot name="head" />
  </head>
  <body>
    <nldd-app-view background="default">
      <nldd-page>
        <nldd-top-navigation-bar
          slot="header"
          logo-title="Polder"
          logo-subtitle="Publieke Overheid: Leden, Dienstverbanden, Eenheden, Rollen"
          logo-href={`${base}/`}
        >
          <nldd-menu-bar-item
            slot="global"
            href={`${base}/personen/`}
            text="Personen"
          ></nldd-menu-bar-item>
          <nldd-menu-bar-item
            slot="global"
            href={`${base}/organisaties/`}
            text="Organisaties"
          ></nldd-menu-bar-item>
          <nldd-menu-bar-item
            slot="global"
            href={`${base}/posten/`}
            text="Posten"
          ></nldd-menu-bar-item>
          <nldd-menu-bar-item
            slot="global"
            href={`${base}/stats/`}
            text="Statistieken"
          ></nldd-menu-bar-item>
          <nldd-menu-bar-item
            slot="global"
            href={`${base}/organogram/`}
            text="Organogram"
          ></nldd-menu-bar-item>
        </nldd-top-navigation-bar>
        <main>
          <slot />
        </main>
        <slot name="after-main" />
      </nldd-page>
    </nldd-app-view>

    <script>
      import '@nldd/design-system';
    </script>

    <style is:global>
      /* NLDD ships its own @font-face with font-display: swap. We rely on
         the preload <link> in <head> to put the regular weight in cache
         before first paint, which eliminates the FOUT on initial load.
         For subsequent navigation, the View Transitions router keeps the
         DOM live so fonts are never re-fetched. */
      :root {
        color-scheme: light;
      }
      html, body {
        margin: 0;
        padding: 0;
        min-height: 100%;
      }
      body {
        font-family: RijksSans, system-ui, sans-serif;
        color: var(--semantics-content-color);
        background-color: var(--semantics-surfaces-background-color);
      }
      /* nldd-app-view is display:flex with height:100% — give it room.
         Using height:100vh + the internal nldd-page scroll keeps the
         top-nav fixed at the top while content scrolls underneath. */
      nldd-app-view {
        height: 100vh;
      }
      /* Force the global menu-bar to show even at narrow widths.
         Top-nav only renders global items when it has `.has-global-items`
         on the host or above a container-width threshold; we use the
         class hook so the links are visible. */
      nldd-top-navigation-bar {
        --_force-global: 1;
      }
      main {
        max-width: 72rem;
        margin: 0 auto;
        padding: 2rem 1.5rem 4rem;
        width: 100%;
        box-sizing: border-box;
      }
      a {
        color: inherit;
      }
      .grid {
        display: grid;
        gap: 1rem;
      }
      .grid-2 {
        grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
      }
      .muted {
        color: var(--semantics-content-secondary-color, #555);
      }

      /* ---- Card dashboard ---- */
      .card-grid {
        display: grid;
        gap: 1.25rem;
        grid-template-columns: repeat(auto-fit, minmax(20rem, 1fr));
        align-items: start;
      }
      .card-grid .span-2 {
        grid-column: span 2;
      }
      @media (max-width: 48rem) {
        .card-grid .span-2 {
          grid-column: span 1;
        }
      }
      .card {
        background: var(--semantics-surfaces-background-color, #fff);
        border: 1px solid var(--primitives-color-coolgray-200, #d9dee5);
        border-radius: 10px;
        padding: 1.25rem 1.5rem;
        border-top: 3px solid
          var(--card-accent, var(--primitives-color-lintblauw-500, #0058a3));
        min-width: 0;
      }
      .card > h2 {
        margin: 0 0 0.75rem;
        font-size: 1.05rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--semantics-content-color, #1a1a1a);
      }
      .card .card-icon {
        color: var(--card-accent, var(--primitives-color-lintblauw-500, #0058a3));
        flex: none;
      }
      .card > details > summary {
        cursor: pointer;
        color: var(--semantics-content-secondary-color, #555);
        margin-bottom: 0.5rem;
      }
      .lede {
        font-size: 1.05rem;
        line-height: 1.5;
        color: var(--semantics-content-secondary-color, #555);
        max-width: 56ch;
      }
      .career {
        font-size: 1.05rem;
        line-height: 1.5;
      }

      /* ---- Badges / chips ---- */
      .badge {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        padding: 0.15rem 0.55rem;
        border-radius: 999px;
        font-size: 0.8rem;
        line-height: 1.4;
        background: var(--primitives-color-coolgray-50, #ebeef2);
        color: var(--semantics-content-secondary-color, #555);
        border: 1px solid var(--primitives-color-coolgray-200, #d9dee5);
        text-decoration: none;
      }
      a.badge:hover {
        border-color: var(--primitives-color-lintblauw-500, #0058a3);
      }
      .badge--lint {
        background: color-mix(
          in srgb,
          var(--primitives-color-lintblauw-500, #0058a3) 12%,
          #fff
        );
        color: var(--primitives-color-lintblauw-500, #0058a3);
        border-color: transparent;
      }
      .badge--warn {
        background: #fdf2e0;
        color: #8a5a00;
        border-color: transparent;
      }
      .badge-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
      }

      /* ---- Graphical mandate timeline ---- */
      .tl {
        display: flex;
        flex-direction: column;
        gap: 0.65rem;
      }
      .tl-axis {
        display: flex;
        justify-content: space-between;
        font-size: 0.75rem;
        color: var(--semantics-content-secondary-color, #555);
        border-bottom: 1px solid var(--primitives-color-coolgray-100, #d9dee5);
        padding-bottom: 0.2rem;
      }
      .tl-row {
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
      }
      .tl-track {
        position: relative;
        height: 1.5rem;
        background: var(--primitives-color-coolgray-50, #ebeef2);
        border-radius: 4px;
      }
      .tl-bar {
        position: absolute;
        top: 0;
        bottom: 0;
        min-width: 3px;
        border-radius: 4px;
        background: var(--bar-accent, var(--primitives-color-lintblauw-500, #0058a3));
        display: block;
      }
      .tl-bar--current {
        background-image: repeating-linear-gradient(
          45deg,
          rgba(255, 255, 255, 0.35) 0 6px,
          transparent 6px 12px
        );
      }
      .tl-label {
        font-size: 0.85rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
        align-items: baseline;
      }
      .tl-label .tl-period {
        color: var(--semantics-content-secondary-color, #555);
      }
      @media (max-width: 40rem) {
        .tl-axis {
          display: none;
        }
        .tl-track {
          height: auto;
          background: none;
        }
        .tl-bar {
          position: static;
          width: auto !important;
          height: 0.5rem;
        }
      }
      /* ---- Seat bar (raad) ---- */
      .seatbar {
        display: flex;
        height: 1.6rem;
        border-radius: 4px;
        overflow: hidden;
        border: 1px solid var(--primitives-color-coolgray-200, #d9dee5);
      }
      .seatbar > span {
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.7rem;
        color: #fff;
        white-space: nowrap;
        overflow: hidden;
      }
      .stat-row {
        display: flex;
        flex-wrap: wrap;
        gap: 1.5rem;
      }
      .stat .stat-num {
        font-size: 1.5rem;
        font-weight: 600;
      }
      .stat .stat-lbl {
        font-size: 0.8rem;
        color: var(--semantics-content-secondary-color, #555);
      }
      .stack {
        display: flex;
        flex-direction: column;
        gap: 1rem;
      }
      table.data {
        width: 100%;
        border-collapse: collapse;
      }
      table.data th, table.data td {
        text-align: left;
        padding: 0.5rem 0.75rem;
        border-bottom: 1px solid #e5e5e5;
        vertical-align: top;
      }
      table.data th {
        font-weight: 600;
        background: #fafafa;
      }
    </style>

    <script>
      // The top-navigation-bar only shows global menu items when the host
      // has the `has-global-items` class (see top-navigation-bar.styles.js
      // selectors `:host(.has-global-items) &`). The class is normally
      // toggled by the component itself based on slotted content, but in
      // SSR-rendered Astro markup the slot-change can race the class
      // application — set it explicitly once the component is defined.
      customElements.whenDefined('nldd-top-navigation-bar').then(() => {
        for (const nav of document.querySelectorAll('nldd-top-navigation-bar')) {
          nav.classList.add('has-global-items');
        }
      });
    </script>
  </body>
</html>
