---
import '@nldd/design-system/styles';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
  background?: 'default' | 'tinted';
}

const { title, description, background = 'default' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// First path segment after the base, used to mark the active nav item.
const path = Astro.url.pathname.replace(base, '').replace(/^\/+/, '');
const section = path.split('/')[0] ?? '';

// Icons omitted for now: NLDD 0.8.43's icon set lacks a role/post-badge and
// an org-chart glyph, so Posten/Organogram had no honest icon. See
// web/docs/nldd-feature-requests.md entry 5.
const nav = [
  { href: `${base}/personen/`, text: 'Personen', match: 'personen' },
  { href: `${base}/organisaties/`, text: 'Organisaties', match: 'organisaties' },
  { href: `${base}/posten/`, text: 'Posten', match: 'posten' },
  { href: `${base}/stats/`, text: 'Statistieken', match: 'stats' },
  { href: `${base}/organogram/`, text: 'Organogram', match: 'organogram' },
];
const repo = 'https://github.com/anneschuth/polder';
const releases = `${repo}/releases/latest`;
---
<!doctype html>
<html lang="nl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · Polder</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" href={`${base}/favicon.svg`} type="image/svg+xml" />
    <ClientRouter />
    <slot name="head" />
  </head>
  <body>
    <nldd-app-view background={background}>
      <nldd-page>
        <nldd-top-navigation-bar
          slot="header"
          logo-title="Polder"
          logo-href={`${base}/`}
        >
          {nav.map((item) => (
            <nldd-menu-bar-item
              slot="global"
              href={item.href}
              text={item.text}
              current={section === item.match ? true : undefined}
            ></nldd-menu-bar-item>
          ))}
          <nldd-menu-bar-item
            slot="utility"
            href={releases}
            text="Download"
            icon="download"
          ></nldd-menu-bar-item>
          <nldd-menu-bar-item
            slot="utility"
            href={repo}
            text="GitHub"
            icon="code"
          ></nldd-menu-bar-item>
        </nldd-top-navigation-bar>
        <main>
          <slot />
        </main>
        <slot name="after-main" />
      </nldd-page>
    </nldd-app-view>

    <script>
      import '@nldd/design-system';
    </script>

    <script>
      // Eén gedelegeerde handler voor alle <nldd-icon-button class="copy-btn">.
      // data-copy bevat de ruwe waarde; na succes 1,2s het icoon naar
      // check-mark wisselen als bevestiging.
      document.addEventListener('click', async (e) => {
        const btn = (e.target as HTMLElement)?.closest('.copy-btn[data-copy]');
        if (!btn) return;
        await navigator.clipboard.writeText(btn.getAttribute('data-copy') ?? '');
        btn.setAttribute('icon', 'check-mark');
        window.setTimeout(() => btn.setAttribute('icon', 'square-on-square'), 1200);
      });
    </script>

    <style is:global>
      /* NLDD ships its own @font-face with font-display: swap. We rely on
         the preload <link> in <head> to put the regular weight in cache
         before first paint, which eliminates the FOUT on initial load.
         For subsequent navigation, the View Transitions router keeps the
         DOM live so fonts are never re-fetched. */
      :root {
        color-scheme: light;
      }
      html, body {
        margin: 0;
        padding: 0;
        min-height: 100%;
      }
      body {
        font-family: RijksSans, system-ui, sans-serif;
        color: var(--semantics-content-color);
        background-color: var(--semantics-surfaces-background-color);
      }
      /* nldd-app-view is display:flex with height:100% — give it room.
         Using height:100vh + the internal nldd-page scroll keeps the
         top-nav fixed at the top while content scrolls underneath. */
      nldd-app-view {
        height: 100vh;
      }
      main {
        max-width: 72rem;
        margin: 0 auto;
        padding: 2rem 1.5rem 4rem;
        width: 100%;
        box-sizing: border-box;
      }
      a {
        color: inherit;
      }
      .grid {
        display: grid;
        gap: 1rem;
      }
      .grid-2 {
        grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
      }
      .muted {
        color: var(--semantics-content-secondary-color);
      }

      /* ---- Section + definition-list layout ----
         No card boxes. One continuous page: each data block is a section
         with a heading + underline rule, followed by a dense label/value
         grid. Works for thin entities (no empty boxes) and rich ones alike. */
      .sections {
        display: flex;
        flex-direction: column;
        gap: 2.25rem;
      }
      /* nldd-simple-section adds its own internal padding; the page already
         spaces sections via .sections gap, so strip the section's block
         padding and let the heading rule own the spacing. */
      nldd-simple-section.section {
        --layout-page-section-padding-block: 0;
        --layout-page-section-padding-inline: 0;
        display: block;
      }
      .section-head {
        margin: 0 0 0.9rem;
        font-size: 0.95rem;
        font-weight: 600;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--semantics-content-color);
        border-bottom: 1px solid var(--primitives-color-coolgray-100);
        padding-bottom: 0.6rem;
      }
      .section .card-icon {
        color: var(--card-accent, var(--primitives-color-accent-500));
        flex: none;
        display: inline-flex;
        width: 1.15rem;
        height: 1.15rem;
      }
      .section .card-icon svg {
        width: 100%;
        height: 100%;
      }
      details.section > summary {
        cursor: pointer;
        list-style: none;
      }
      details.section > summary::-webkit-details-marker {
        display: none;
      }
      details.section[open] > summary .section-head {
        margin-bottom: 0.9rem;
      }
      /* Dense label/value grid. Label is a fixed muted column, value next to
         it. Auto-fills 2-3 columns on wide screens, 1 on narrow. */
      .deflist {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(22rem, 1fr));
        gap: 0.55rem 2.5rem;
        align-items: baseline;
      }
      .deflist > div {
        display: grid;
        grid-template-columns: 10rem 1fr;
        gap: 0 1rem;
        align-items: baseline;
      }
      .deflist dt {
        color: var(--semantics-content-secondary-color);
        font-size: 0.9rem;
      }
      .deflist dd {
        margin: 0;
      }
      @media (max-width: 32rem) {
        .deflist > div {
          grid-template-columns: 1fr;
          gap: 0;
        }
      }
      /* Long URLs / codes wrap instead of overflowing. */
      .section a,
      .section code,
      .deflist dd {
        overflow-wrap: anywhere;
        word-break: break-word;
      }

      /* Edit-on-GitHub affordance. Globaal (niet scoped) zodat het ook
         werkt binnen design-system web-componenten. Altijd zichtbaar maar
         subtiel; oplichtend bij hover/focus van het hele key+value-blok.
         Geen hover-reveal: dat faalt binnen shadow-DOM-componenten. */
      .edit-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 1.05em;
        height: 1.05em;
        margin-inline-start: 0.4em;
        vertical-align: middle;
        color: var(--semantics-content-secondary-color, #8a8a8a);
        text-decoration: none;
        line-height: 1;
        opacity: 0.35;
        transition:
          opacity 0.12s ease-in-out,
          color 0.12s ease-in-out;
      }
      .edit-link svg {
        display: block;
        width: 14px;
        height: 14px;
        flex: none;
      }
      .editable:hover .edit-link,
      .editable:focus-within .edit-link,
      .deflist > div:hover .edit-link,
      tr:hover .edit-link,
      li:hover .edit-link,
      nldd-list-item:hover .edit-link,
      h1:hover .edit-link {
        opacity: 1;
        color: var(--semantics-content-default-color, #1a1a1a);
      }
      .edit-link:hover,
      .edit-link:focus,
      .edit-link:focus-visible {
        opacity: 1;
        color: var(--semantics-content-default-color, #1a1a1a);
      }
      /* Kopieer-knop: <nldd-icon-button> styelt zichzelf; alleen iets
         gedempt tot het blok hover/focus krijgt, net als .edit-link. */
      .copy-btn {
        opacity: 0.45;
        transition: opacity 0.12s ease-in-out;
      }
      .deflist > div:hover .copy-btn,
      .deflist > div:focus-within .copy-btn,
      .copy-btn:hover,
      .copy-btn:focus-within {
        opacity: 1;
      }

      /* Klok-stempel: icoon en tekst op één regel uitgelijnd. */
      .timestamp {
        display: inline-flex;
        align-items: center;
        gap: 0.35em;
      }

      .lede {
        font-size: 1.05rem;
        line-height: 1.6;
        color: var(--semantics-content-secondary-color);
      }
      .career {
        font-size: 1.05rem;
        line-height: 1.5;
      }

      /* ---- Chips: <nldd-tag>, optionally wrapped in a link ---- */
      .badge-link {
        text-decoration: none;
        display: inline-flex;
      }
      .badge-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
        align-items: center;
      }
      .seat-legend {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
      }
      .seat-dot {
        width: 0.7rem;
        height: 0.7rem;
        border-radius: 999px;
        flex: none;
      }

      /* ---- Graphical mandate timeline ---- */
      .tl {
        display: flex;
        flex-direction: column;
        gap: 0.65rem;
      }
      .tl-axis {
        display: flex;
        justify-content: space-between;
        font-size: 0.75rem;
        color: var(--semantics-content-secondary-color);
        border-bottom: 1px solid var(--primitives-color-coolgray-100);
        padding-bottom: 0.2rem;
      }
      .tl-row {
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
      }
      .tl-track {
        position: relative;
        height: 1.5rem;
        background: var(--primitives-color-coolgray-50);
        border-radius: 4px;
        overflow: hidden;
      }
      .tl-bar {
        position: absolute;
        top: 0;
        bottom: 0;
        min-width: 3px;
        max-width: 100%;
        border-radius: 4px;
        background: var(--bar-accent, var(--primitives-color-accent-500));
        display: block;
      }
      .tl-bar--current {
        background-image: repeating-linear-gradient(
          45deg,
          color-mix(in srgb, var(--primitives-color-coolgray-0) 35%, transparent)
            0 6px,
          transparent 6px 12px
        );
      }
      .tl-label {
        font-size: 0.85rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
        align-items: baseline;
      }
      .tl-label .tl-period {
        color: var(--semantics-content-secondary-color);
      }
      .tl-legend {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem 1rem;
        margin-top: 0.5rem;
        padding-top: 0.6rem;
        font-size: 0.8rem;
        color: var(--semantics-content-secondary-color);
        border-top: 1px solid var(--primitives-color-coolgray-100);
      }
      @media (max-width: 40rem) {
        .tl-axis {
          display: none;
        }
        .tl-track {
          height: auto;
          background: none;
        }
        .tl-bar {
          position: static;
          width: auto !important;
          height: 0.5rem;
        }
      }
      /* ---- Seat bar (raad) ---- */
      .seatbar {
        display: flex;
        height: 1.6rem;
        border-radius: 4px;
        overflow: hidden;
        border: 1px solid var(--primitives-color-coolgray-200);
      }
      .seatbar > span {
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.7rem;
        color: var(--primitives-color-coolgray-0);
        white-space: nowrap;
        overflow: hidden;
      }
      .stat-row {
        display: flex;
        flex-wrap: wrap;
        gap: 1.5rem;
      }
      .stat .stat-num {
        font-size: 1.5rem;
        font-weight: 600;
      }
      .stat .stat-lbl {
        font-size: 0.8rem;
        color: var(--semantics-content-secondary-color);
      }
      .stack {
        display: flex;
        flex-direction: column;
        gap: 1rem;
      }
      table.data {
        width: 100%;
        border-collapse: collapse;
      }
      table.data th, table.data td {
        text-align: left;
        padding: 0.5rem 0.75rem;
        border-bottom: 1px solid var(--primitives-color-coolgray-100);
        vertical-align: top;
      }
      table.data th {
        font-weight: 600;
        background: var(--primitives-color-coolgray-25);
      }
    </style>
  </body>
</html>
